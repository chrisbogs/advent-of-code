<div class="top-row pl-4 navbar navbar-dark">
    <a class="navbar-brand" href="https://adventofcode.com/" target="_blank" rel="noopener noreferrer">
        <span class="oi oi-calendar" aria-hidden="true"></span> Advent of Code
    </a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Home
            </NavLink>
        </li>
        @foreach (var year in Years)
        {
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@year.ToString()">
                    <span class="oi oi-calendar" aria-hidden="true"></span> @year
                </NavLink>
            </li>
        }
    </ul>
</div>

@code {
    private bool collapseNavMenu = true;
    private List<int> Years { get; set; } = new();

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override void OnInitialized()
    {
        // Generate years from 2015 to current year
        var currentYear = DateTime.Now.Year;
        Years = Enumerable.Range(2015, currentYear - 2015 + 1).Reverse().ToList();
    }
}
