@inject ApiService Api

<div class="year-result-container">
    <h1 class="year-title">Advent of Code @Year</h1>

    @if (loading)
    {
        <div class="loading-message">Loading results...</div>
    }
    else
    {
        <div class="days-grid">
            @for (int day = 1; day <= 25; day++)
            {
                var currentDay = day;  // Capture the current value to avoid closure issue
                <DayResult Day="currentDay"
                          GetPart1Result="@(() => GetResult(currentDay, 1))"
                          GetPart2Result="@(() => GetResult(currentDay, 2))" />
            }
        </div>
    }
</div>

@code {
    [Parameter] public int Year { get; set; }

    private bool loading = false;

    private async Task<string> GetResult(int day, int part)
    {
        try
        {
            var result = await Api.GetResult(Year, day, part);
            return result ?? string.Empty;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading result for day {day}, part {part}: {ex.Message}");
            return string.Empty;
        }
    }
}